# ---------------------------
# Service endpoints
# ---------------------------
REDIS_ADDR=redis-cart:6379
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_ALLOWED_HOSTS=127.0.0.1,localhost,ollama
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=60

# ---------------------------
# shoppingassistantservice model and retrieval
# ---------------------------
MODEL_PROVIDER=gemini
GEMINI_VISION_MODEL=gemini-1.5-flash
GEMINI_TEXT_MODEL=gemini-1.5-flash
VECTORSTORE_BACKEND=alloydb
VECTOR_TOP_K=6
PRODUCT_CATALOG_JSON=/shoppingassistantservice/products.local.json
PROMPT_TEMPLATE_DIR=/shoppingassistantservice/prompts/v1
MAX_RETRIES=2
RETRY_BACKOFF_SECONDS=0.4
CIRCUIT_BREAKER_FAILURE_THRESHOLD=4
CIRCUIT_BREAKER_RESET_SECONDS=30
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
ENABLE_TRACING=1
OTEL_SERVICE_NAME=shoppingassistantservice
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ---------------------------
# AlloyDB / Postgres credentials
# ---------------------------
PROJECT_ID=your-project-id
REGION=asia-east1
ALLOYDB_CLUSTER_NAME=your-alloydb-cluster
ALLOYDB_INSTANCE_NAME=your-alloydb-instance
ALLOYDB_DATABASE_NAME=products
ALLOYDB_TABLE_NAME=catalog_items
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=
ALLOYDB_SECRET_NAME=alloydb-secret
